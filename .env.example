# ──────────────────────────────────────────────
# 클라이언트 (브라우저로 노출되는 키)
# ──────────────────────────────────────────────

# 카카오맵 JavaScript 키 — 지도 SDK용
# 카카오 콘솔: 내 앱 → 앱 키 → "JavaScript 키"
# 보안: 콘솔의 "플랫폼 → Web"에 도메인 등록으로 보장
VITE_KAKAO_JS_KEY=여기에_카카오_JavaScript_키

# ──────────────────────────────────────────────
# 서버 전용 (Vercel Serverless Function 에서만 사용)
# VITE_ 접두사를 붙이지 않아 클라이언트에 노출되지 않음
# ──────────────────────────────────────────────

# 카카오 REST API 키 — 로컬 검색(쉼터/화장실), 자동차 길찾기(도보 근사) 용
# 카카오 콘솔: 내 앱 → 앱 키 → "REST API 키"
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키

# (선택) Tmap 보행자 경로 API 키 — 실제 도보 경로 정확도가 가장 높음
# 발급: https://openapi.sk.com — 무료, 1분 가입
# 미설정 시 카카오 자동차 길찾기로 폴백
TMAP_APP_KEY=

# (선택) data.go.kr 공공데이터포털 서비스 키 — 무더위쉼터/공중화장실/장애인편의시설
# 발급: https://www.data.go.kr 가입 → 데이터셋 검색 → "활용신청" → 1~2시간 후 승인
#  · 전국무더위쉼터표준데이터  (datasetId 15013199)
#  · 전국공중화장실표준데이터  (datasetId 15012892, 장애인용 칸 보유 화장실만 필터됨)
#  · 전국장애인편의시설표준데이터 (datasetId 15100058)
# 발급된 "일반 인증키 (Decoding)" 그대로 등록
DATA_GO_KR_SERVICE_KEY=

# (선택) 위 데이터셋의 Open API 엔드포인트 URL을 직접 지정하고 싶을 때
# 데이터셋 상세 페이지의 "엔드포인트" 그대로 복사. 미지정 시 기본값 사용.
# DATA_GO_KR_HEAT_SHELTER_URL=
# DATA_GO_KR_PUBLIC_TOILET_URL=
# DATA_GO_KR_DISABLED_FACILITY_URL=
