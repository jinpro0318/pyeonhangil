# 카카오맵 JavaScript 키
# 발급 방법:
# 1. https://developers.kakao.com 로그인
# 2. 내 애플리케이션 → 애플리케이션 추가
# 3. 앱 키 → "JavaScript 키" 복사
# 4. 앱 설정 → 플랫폼 → Web 플랫폼 등록
#    - 로컬: http://localhost:3000
#    - 배포: https://your-app.vercel.app  (Vercel 도메인 그대로)
VITE_KAKAO_JS_KEY=키 입력

# Firebase (이메일/비밀번호 인증)
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성에서 복사
# Authentication → Sign-in method 에서 "이메일/비밀번호" 활성화 필요
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
